{
  "name": "alumni-book-v2",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  },
  "scripts": {
    "dev:site": "pnpm --filter site dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "build:site": "pnpm --filter site build",
    "build:admin": "pnpm --filter admin build",
    "deploy:worker": "pnpm --filter worker deploy",
    "db:migrate": "pnpm --filter worker db:migrate",
    "migrate:data": "tsx scripts/migrate.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
